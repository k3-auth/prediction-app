  document.getElementById('bet-detail-news-list').innerHTML=b.analysis.news.map(n=>`<a class="bet-news-item" href="$\{n.url\}"><div class="bet-news-title">\uc0\u55357 \u56560  $\{n.title\}</div><div class="bet-news-meta">$\{n.source\} \'95 $\{n.time\}</div></a>`).join('');\
  document.getElementById('modal-bet-detail').classList.add('active');\
\}\
