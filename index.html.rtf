// VIEW SWITCHING\
function setActiveTab(tabId)\{\
  document.querySelectorAll('.header-tab').forEach(t=>t.classList.toggle('active',t.dataset.tab===tabId));\
\}\
function switchView(viewId)\{\
  document.querySelectorAll('.view-section').forEach(el=>\{el.classList.remove('active');el.style.display='none';\});\
  const t=document.getElementById('view-'+viewId);\
  if(t)\{t.classList.add('active');t.style.display='block';\}\
  const tabMap=\{home:'home',mypage:'mypage',mission:'mission',cards:'cards',wbc:'home'\};\
  setActiveTab(tabMap[viewId]||'home');\
  if(viewId==='mission') renderMissionSection();\
  if(viewId==='cards')\{renderPackGrid();renderCollectionGrid();document.getElementById('header-balance').style.display='none';\}\
  else document.getElementById('header-balance').style.display='block';\
  window.scrollTo(0,0);\
\}\
function showScreen(id)\{\
  if(id==='home')\{switchView('home');\}\
  else if(id==='mypage')\{switchView('mypage');setActiveTab('mypage');renderMpBets();renderMpActiveBets();renderMpFriends();renderMpLeague();\}\
  else if(id==='rankingDetail')\{\
    document.querySelectorAll('.view-section').forEach(el=>\{el.classList.remove('active');el.style.display='none';\});\
    const t=document.getElementById('rankingDetail');if(t)\{t.classList.add('active');t.style.display='block';\}\
    renderRankingDetail();window.scrollTo(0,0);\
  \}\
\}\
