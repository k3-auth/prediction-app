// CARDS\
function renderPackGrid()\{\
  const el=document.getElementById('pack-grid');if(!el)return;\
  el.innerHTML=packs.map(p=>`<div class="pack-card" onclick="openBuyModal('$\{p.id\}')"><div class="pack-bg" style="background:$\{p.bg\};"></div><div class="pack-content"><div class="pack-image-area">\uc0\u55357 \u56550 </div><div class="pack-title">$\{p.name\}</div><div class="pack-desc">$\{p.desc\}</div><div class="pack-rarity">$\{p.rarity\}</div><div class="pack-price"><span class="coin-paid">\u55357 \u56496  $\{p.costPaid\}</span> / <span class="coin-free">\u55358 \u56985  $\{p.costFree\}</span></div><div class="btn-buy-pack">\u36092 \u20837 \u12377 \u12427 </div></div></div>`).join('');\
\}\
function renderCollectionGrid()\{\
  const el=document.getElementById('collection-grid');if(!el)return;\
  el.innerHTML=myCollection.map(c=>`<div class="collection-card rarity-$\{c.rarity\}" onclick="showCollectionCardDetail($\{c.id\})">$\{c.isNew?'<div class="new-badge">NEW</div>':''\}<div class="card-emoji">$\{c.emoji\}</div><div class="card-name">$\{c.name\}</div><div class="card-rarity">$\{c.rarity\}</div></div>`).join('');\
\}\
function showCollectionCardDetail(id)\{\
  const c=myCollection.find(x=>x.id===id);if(!c)return;\
  document.getElementById('detail-emoji').textContent=c.emoji;\
  document.getElementById('detail-name').textContent=c.name;\
  document.getElementById('detail-team').textContent=`$\{c.team\} ($\{c.sport\})`;\
  document.getElementById('detail-rarity').textContent=c.rarity;\
  document.getElementById('modal-card-detail').classList.add('active');\
\}\
function openBuyModal(packId)\{\
  currentSelectedPack=packs.find(p=>p.id===packId);if(!currentSelectedPack)return;\
  document.getElementById('buy-modal-title').textContent=`\uc0\u55357 \u56550  $\{currentSelectedPack.name\}`;\
  document.getElementById('buy-cost-paid').textContent=currentSelectedPack.costPaid;\
  document.getElementById('buy-cost-free').textContent=currentSelectedPack.costFree;\
  document.getElementById('radio-paid').checked=true;updateBuyModal();\
  document.getElementById('modal-buy-pack').classList.add('active');\
\}\
function updateBuyModal()\{\
  const isPaid=document.getElementById('radio-paid').checked;\
  const cost=isPaid?currentSelectedPack.costPaid:currentSelectedPack.costFree;\
  const bal=isPaid?coins.paid:coins.free;\
  const after=bal-cost;\
  const type=isPaid?'\uc0\u55357 \u56496 ':'\u55358 \u56985 ';\
  document.getElementById('buy-balance-calc').textContent=`$\{type\} $\{bal.toLocaleString()\} \uc0\u8594  \u36092 \u20837 \u24460 : $\{after.toLocaleString()\}`;\
  const err=after<0;\
  document.getElementById('buy-error').style.display=err?'block':'none';\
  document.getElementById('btn-confirm-buy').disabled=err;\
\}\
function confirmBuyPack()\{\
  const isPaid=document.getElementById('radio-paid').checked;\
  const cost=isPaid?currentSelectedPack.costPaid:currentSelectedPack.costFree;\
  if(isPaid)coins.paid-=cost;else coins.free-=cost;\
  document.getElementById('coin-paid-display').textContent=coins.paid.toLocaleString();\
  document.getElementById('coin-free-display').textContent=coins.free.toLocaleString();\
  closeModal('modal-buy-pack');\
  openPackModal();\
\}\
function openPackModal()\{\
  const area=document.getElementById('open-pack-area');\
  area.innerHTML=Array(5).fill(0).map(()=>`<div class="flip-card"><div class="flip-card-front">\uc0\u55356 \u57268 </div><div class="flip-card-back"><div class="emoji">\u9918 </div><div class="name">???</div><div class="rarity">RARE</div></div></div>`).join('');\
  document.getElementById('open-pack-msg').style.display='none';\
  document.getElementById('btn-open-all').style.display='block';\
  document.getElementById('btn-close-open').style.display='none';\
  document.getElementById('modal-open-pack').classList.add('active');\
\}\
function openAllCards()\{\
  document.querySelectorAll('.flip-card').forEach((c,i)=>\{setTimeout(()=>c.classList.add('flipped'),i*200);\});\
  setTimeout(()=>\{\
    document.getElementById('open-pack-msg').style.display='block';\
    document.getElementById('btn-open-all').style.display='none';\
    document.getElementById('btn-close-open').style.display='block';\
  \},1500);\
\}\
\
// MISSION\
function renderMissionSection()\{\
  const el=document.getElementById('mission-container');if(!el)return;\
  let html='';\
  const renderGroup=(title,list)=>\{\
    html+=`<div style="margin-bottom:1.5rem;"><div class="section-header"><span>$\{title\}</span></div>`;\
    list.forEach(m=>\{\
      const pct=Math.round(m.progress.current/m.progress.total*100);\
      html+=`<div class="mission-card$\{m.done?' done':''\}"><div class="mission-card-info"><div class="mission-name">$\{m.done?'\uc0\u9989  ':''\}$\{m.title\}</div><div style="display:flex;align-items:center;gap:6px;margin-top:4px;"><div class="mission-progress-bar-bg"><div class="mission-progress-bar-fill" style="width:$\{pct\}%"></div></div><span style="font-size:10px;color:#8b949e;">$\{m.progress.current\}/$\{m.progress.total\}</span></div></div><div class="mission-reward-text$\{m.done?' done':''\}">+$\{m.reward\}pt</div></div>`;\
    \});\
    html+='</div>';\
  \};\
  renderGroup('\uc0\u55357 \u56517  \u12487 \u12452 \u12522 \u12540 \u12511 \u12483 \u12471 \u12519 \u12531 ',missions.daily);\
  renderGroup('\uc0\u55357 \u56518  \u12454 \u12451 \u12540 \u12463 \u12522 \u12540 \u12511 \u12483 \u12471 \u12519 \u12531 ',missions.weekly);\
  el.innerHTML=html;\
\}\
\
// MODAL\
function closeModal(id)\{document.getElementById(id)?.classList.remove('active');\}\
\
// INIT\
renderHomeMatches();\
renderPlayerCards();\
renderPackGrid();\
renderCollectionGrid();\
\
// ODDS UPDATE\
setInterval(()=>\{\
  const btns=document.querySelectorAll('.odds-btn');\
  if(!btns.length)return;\
  const btn=btns[Math.floor(Math.random()*btns.length)];\
  let o=parseFloat(btn.dataset.odds)+((Math.random()*0.1)-0.05);\
  if(o<1.01)o=1.01;o=Math.round(o*100)/100;\
  btn.querySelector('.odds-value').textContent=o.toFixed(2);\
  const prev=parseFloat(btn.dataset.odds);btn.dataset.odds=o.toFixed(2);\
  btn.classList.remove('flash-up','flash-down');void btn.offsetWidth;\
  btn.classList.add(o>prev?'flash-up':'flash-down');\
\},3000);\
</script>\
</body>\
</html>}