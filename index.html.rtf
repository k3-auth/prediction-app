// BETSLIP\
const state = \{bets:[],balance:10000\};\
const betslipItemsEl = document.getElementById('betslip-items');\
const betslipCountEl = document.getElementById('betslip-count');\
const mobileCountEl  = document.getElementById('mobile-count');\
const totalStakeEl   = document.getElementById('total-stake');\
const totalReturnEl  = document.getElementById('total-return');\
const placeBetBtn    = document.getElementById('place-bet-btn');\
const mobileToggleEl = document.getElementById('mobile-toggle');\
const betslipPanelEl = document.getElementById('betslip-panel');\
\
document.querySelectorAll('.odds-btn').forEach(btn => \{\
  btn.addEventListener('click', function()\{\
    toggleBet(this.dataset.id, this.dataset.market, this.dataset.selection, parseFloat(this.dataset.odds));\
  \});\
\});\
\
function toggleBet(id,market,selection,odds)\{\
  const idx=state.bets.findIndex(b=>b.id===id);\
  if(idx>=0)\{state.bets.splice(idx,1);document.querySelector(`.odds-btn[data-id="$\{id\}"]`)?.classList.remove('selected');\}\
  else\{state.bets.push(\{id,market,selection,odds,stake:0\});document.querySelector(`.odds-btn[data-id="$\{id\}"]`)?.classList.add('selected');if(window.innerWidth<=1024&&state.bets.length===1)\{betslipPanelEl.classList.add('open');mobileToggleEl.classList.add('hidden');\}\}\
  renderBetslip();\
\}\
function renderBetslip()\{\
  betslipCountEl.textContent=state.bets.length;mobileCountEl.textContent=state.bets.length;placeBetBtn.disabled=state.bets.length===0;\
  if(state.bets.length===0)\{betslipItemsEl.innerHTML='<div class="empty-betslip"><p>\uc0\u20104 \u24819 \u12364 \u36984 \u25246 \u12373 \u12428 \u12390 \u12356 \u12414 \u12379 \u12435 </p><p style="margin-top:6px;font-size:11px;">\u20493 \u29575 \u12434 \u12479 \u12483 \u12503 \u12375 \u12390 \u20104 \u24819 \u12434 \u36861 \u21152 </p></div>';updateTotals();return;\}\
  betslipItemsEl.innerHTML='';\
  state.bets.forEach(bet=>\{\
    const item=document.createElement('div');item.className='bet-item';item.id=`bet-item-$\{bet.id\}`;\
    item.innerHTML=`<div style="display:flex;justify-content:space-between;margin-bottom:5px;"><div><div class="bet-selection">$\{bet.selection\}</div><div class="bet-market">$\{bet.market\}</div></div><div class="bet-odds-badge">$\{bet.odds.toFixed(2)\}</div></div><button class="btn-remove" onclick="removeBet('$\{bet.id\}')">\uc0\u10005 </button><div style="position:relative;"><span class="stake-sym">pt</span><input type="number" id="input-$\{bet.id\}" class="stake-input" placeholder="\u21442 \u21152 \u12509 \u12452 \u12531 \u12488 " value="$\{bet.stake>0?bet.stake:''\}" oninput="handleInput('$\{bet.id\}',this.value)"></div><div class="quick-stakes"><button class="btn-quick" onclick="addStake('$\{bet.id\}',500)">+500</button><button class="btn-quick" onclick="addStake('$\{bet.id\}',1000)">+1k</button><button class="btn-quick" onclick="addStake('$\{bet.id\}',5000)">+5k</button><button class="btn-quick" onclick="addStake('$\{bet.id\}','MAX')">MAX</button></div><div class="potential-return"><span>\u21463 \u21462 \u38989 :</span><span id="return-$\{bet.id\}" class="return-amount">$\{Math.floor(bet.stake*bet.odds).toLocaleString()\}pt</span></div>`;\
    betslipItemsEl.appendChild(item);\
  \});\
  updateTotals();\
\}\
window.removeBet=id=>\{document.querySelector(`.odds-btn[data-id="$\{id\}"]`)?.classList.remove('selected');const i=state.bets.findIndex(b=>b.id===id);if(i>=0)state.bets.splice(i,1);renderBetslip();\};\
window.handleInput=(id,v)=>\{const bet=state.bets.find(b=>b.id===id);if(bet)\{bet.stake=parseInt(v)||0;const r=document.getElementById(`return-$\{id\}`);if(r)r.textContent=`$\{Math.floor(bet.stake*bet.odds).toLocaleString()\}pt`;updateTotals();\}\};\
window.addStake=(id,a)=>\{const bet=state.bets.find(b=>b.id===id);if(bet)\{bet.stake=a==='MAX'?state.balance:(bet.stake+a);const inp=document.getElementById(`input-$\{id\}`);if(inp)inp.value=bet.stake;const r=document.getElementById(`return-$\{id\}`);if(r)r.textContent=`$\{Math.floor(bet.stake*bet.odds).toLocaleString()\}pt`;updateTotals();\}\};\
function updateTotals()\{const ts=state.bets.reduce((s,b)=>s+b.stake,0),tr=state.bets.reduce((s,b)=>s+(b.stake*b.odds),0);totalStakeEl.textContent=`$\{ts.toLocaleString()\}pt`;totalReturnEl.textContent=`$\{Math.floor(tr).toLocaleString()\}pt`;\}\
function toggleMobileBetslip()\{if(window.innerWidth>1024)return;betslipPanelEl.classList.toggle('open');mobileToggleEl.classList.toggle('hidden');\}\
