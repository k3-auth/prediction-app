// HOME MATCHES\
function renderHomeMatches()\{\
  const c=document.getElementById('home-matches-container');if(!c)return;\
  let html=`<div style="margin-bottom:2rem;"><div class="section-header"><span>\uc0\u9918  \u27178 \u27996 DeNA\u12505 \u12452 \u12473 \u12479 \u12540 \u12474 </span><button class="see-more-btn">\u12418 \u12387 \u12392 \u35211 \u12427  \'9b</button></div><div class="match-card-list">`;\
  matches.forEach((m,i)=>\{html+=createMatchCardHtml(m,i);\});\
  html+=`</div></div>`;c.innerHTML=html;\
\}\
function createMatchCardHtml(m,idx)\{\
  const hotClass=m.isHot?'is-hot':'';\
  const hotBadge=m.isHot?'<div class="hot-badge">\uc0\u55357 \u56613  HOT</div>':'<div></div>';\
  let sb='',st='';\
  if(m.status==='live')\{sb='status-live';st='LIVE';\}\
  else if(m.status==='upcoming')\{sb=m.deadlineSeconds<3600?'status-closing':'status-upcoming';st=m.deadlineSeconds<3600?'\uc0\u9888 \u65039 \u32224 \u20999 \u38291 \u36817 ':'19:00';\}\
  else\{sb='status-finished';st='\uc0\u32066 \u20102 ';\}\
  const cd=m.status==='live'||m.status==='finished'?'<span style="color:#8b949e;">\uc0\u20104 \u24819 \u32224 \u20999 \u28168 \u12415 </span>':`<span>\u21463 \u20184 \u20013 </span>`;\
  let scoreHtml='';\
  if(m.status==='live'||m.status==='finished')\{\
    scoreHtml=`<div class="csr-row"><span class="csr-home"><span class="csr-flag">$\{m.homeTeam.flag\}</span><span class="csr-name">$\{m.homeTeam.name\}</span></span><span class="csr-center"><span class="csr-num">$\{m.homeTeam.score\}</span><span class="csr-sep"> - </span><span class="csr-num">$\{m.awayTeam.score\}</span></span><span class="csr-away"><span class="csr-name">$\{m.awayTeam.name\}</span><span class="csr-flag">$\{m.awayTeam.flag\}</span></span></div>`;\
  \} else \{\
    scoreHtml=`<div class="csr-row"><span class="csr-home"><span class="csr-flag">$\{m.homeTeam.flag\}</span><span class="csr-name">$\{m.homeTeam.name\}</span></span><span style="font-size:12px;color:#8b949e;flex-shrink:0;">VS</span><span class="csr-away"><span class="csr-name">$\{m.awayTeam.name\}</span><span class="csr-flag">$\{m.awayTeam.flag\}</span></span></div>`;\
  \}\
  let myBetHtml='';\
  if(m.myBet?.status==='placed')myBetHtml=`<div class="part-bar part-done">\uc0\u9989  \u20104 \u24819 \u28168 \u12415 \u65306 <strong>$\{m.myBet.label\}</strong></div>`;\
  else if(m.myBet?.status==='open')myBetHtml=`<div class="part-bar part-open">\uc0\u55357 \u56481  \u12414 \u12384 \u20104 \u24819 \u12375 \u12390 \u12356 \u12414 \u12379 \u12435 <button class="part-btn" onclick="openMatchDetail($\{idx\});event.stopPropagation();">\u20104 \u24819 \u12377 \u12427  \u8594 </button></div>`;\
  else if(m.myBet?.status==='won')myBetHtml=`<div class="part-bar part-won">\uc0\u9989  \u30340 \u20013 \u65306 <strong>$\{m.myBet.label\}</strong></div>`;\
  return `<div class="home-match-card $\{hotClass\}" onclick="openMatchDetail($\{idx\})"><div class="card-top-row">$\{hotBadge\}<div class="status-badge $\{sb\}">$\{st\}</div></div>$\{scoreHtml\}<div class="card-divider"></div><div class="card-meta-section"><div class="meta-row $\{m.isHot?'text-amber':''\}"><span>\uc0\u55357 \u56421 </span><span>$\{m.participants.toLocaleString()\}\u20154 \u12364 \u20104 \u24819 \u20013 </span></div><div class="meta-row"><span>\u9200 </span><span>\u32224 \u20999 \u12414 \u12391  $\{cd\}</span></div></div>$\{myBetHtml\}</div>`;\
\}\
