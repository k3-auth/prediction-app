  const atitle=b.status==='pending'?'\uc0\u55357 \u56522  \u29694 \u22312 \u12398 \u29366 \u27841 ':'\u55357 \u56522  \u35430 \u21512 \u12398 \u25391 \u12426 \u36820 \u12426 ';\
  document.getElementById('bet-detail-analysis-title').textContent=atitle;\
  document.getElementById('bet-detail-analysis-text').textContent=b.analysis.summary;\
  const hs=document.getElementById('bet-detail-hint-section');\
